VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# WARNING: The service role key bypasses Row Level Security and must NEVER be exposed
# to the browser or committed to version control. Use it only in secure server-side
# environments (e.g. backend API, edge functions). Remove the VITE_ prefix if used server-side.
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
